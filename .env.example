# Copy to `.env.local` and fill in. Never commit real keys.

# OpenSea API v2 key — powers the Wilder World Market page (/market), which
# browses live onchain NFTs and metadata. Get one at
# https://docs.opensea.io/reference/api-keys. Read server-side only; if unset,
# the Market page renders a graceful empty state.
OPENSEA_API_KEY=

# Zode shared-password gate (only enforced when AUTH_DISABLED is false in
# src/sites/zode/lib/session-constants.ts). SITE_PASSWORD is the shared
# password checked at /login; SESSION_SECRET signs the session cookie.
SITE_PASSWORD=
SESSION_SECRET=

# Indexer API — primary market data source for the Market page (/market).
# Base URL of the indexing service plus its `x-api-key` value. Read
# server-side only; if either is unset, indexer-backed data renders a
# graceful empty state.
INDEXER_API_URL=
INDEXER_API_KEY=

# ZODE compute-lead webhook — where /buy-compute and /give-compute submissions
# are forwarded (the CRM funnel). Any endpoint that accepts a JSON POST works:
# a Zapier/Make/n8n catch hook, a Slack incoming webhook, HubSpot forms, etc.
# Server-side only. If unset, the API returns 503 and the forms fall back to a
# pre-filled mailto so leads are never silently lost — but set this in prod so
# leads actually land in the CRM.
ZODE_LEADS_WEBHOOK_URL=

# Mixpanel — one public project token per brand site, so each domain reports to
# its own project and never cross-counts. Client-side (NEXT_PUBLIC_*); a site
# with no token set is a silent no-op. The active site's token is selected by
# domain at runtime (see src/features/analytics/mixpanel.ts).
NEXT_PUBLIC_MIXPANEL_TOKEN_CYPHER=
NEXT_PUBLIC_MIXPANEL_TOKEN_WILDERWORLD=
NEXT_PUBLIC_MIXPANEL_TOKEN_ZERO=
NEXT_PUBLIC_MIXPANEL_TOKEN_ZCHAIN=
NEXT_PUBLIC_MIXPANEL_TOKEN_ZODE=
